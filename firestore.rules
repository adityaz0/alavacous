rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(ownerId) {
      return signedIn() && request.auth.uid == ownerId;
    }

    function projectPath(projectId) {
      return /databases/$(database)/documents/projects/$(projectId);
    }

    function applicationPath(projectId, userId) {
      return /databases/$(database)/documents/applications/$(projectId + '_' + userId);
    }

    function onlyApplicantCountIncremented(projectId) {
      return signedIn()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'applicantCount',
          'updatedAt'
        ])
        && request.resource.data.applicantCount == resource.data.applicantCount + 1
        && !exists(applicationPath(projectId, request.auth.uid))
        && existsAfter(applicationPath(projectId, request.auth.uid));
    }

    function onlyApplicantCountWithdrawn(projectId) {
      return signedIn()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'applicantCount',
          'updatedAt'
        ])
        && exists(applicationPath(projectId, request.auth.uid))
        && !existsAfter(applicationPath(projectId, request.auth.uid))
        && (
          (
            resource.data.applicantCount > 0
            && request.resource.data.applicantCount == resource.data.applicantCount - 1
          )
          || (
            resource.data.applicantCount == 0
            && request.resource.data.applicantCount == 0
          )
        );
    }

    function ownerProjectFieldsAreStable() {
      return request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.applicantCount == resource.data.applicantCount
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    function projectData(projectId) {
      return get(projectPath(projectId)).data;
    }

    function withdrawalKeepsApplicantCountSafe(projectId) {
      return exists(projectPath(projectId))
        && existsAfter(projectPath(projectId))
        && (
          (
            projectData(projectId).applicantCount > 0
            && getAfter(projectPath(projectId)).data.applicantCount == projectData(projectId).applicantCount - 1
          )
          || (
            projectData(projectId).applicantCount == 0
            && getAfter(projectPath(projectId)).data.applicantCount == 0
          )
        );
    }

    function acceptedApplicationPath(projectId, userId) {
      return applicationPath(projectId, userId);
    }

    function isAcceptedProjectMember(projectId) {
      return signedIn()
        && exists(acceptedApplicationPath(projectId, request.auth.uid))
        && get(acceptedApplicationPath(projectId, request.auth.uid)).data.status == 'Accepted';
    }

    function chatPath(chatId) {
      return /databases/$(database)/documents/chats/$(chatId);
    }

    function isChatMember(chatId) {
      return signedIn()
        && exists(chatPath(chatId))
        && request.auth.uid in get(chatPath(chatId)).data.members;
    }

    function chatApplicationPath(projectId, applicantId) {
      return /databases/$(database)/documents/applications/$(projectId + '_' + applicantId);
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create, update: if isOwner(userId);
      allow delete: if false;
    }

    match /projects/{projectId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.applicantCount == 0;
      allow update: if (isOwner(resource.data.ownerId) && ownerProjectFieldsAreStable())
        || onlyApplicantCountIncremented(projectId)
        || onlyApplicantCountWithdrawn(projectId);
      allow delete: if isOwner(resource.data.ownerId);
    }

    match /applications/{applicationId} {
      allow create: if signedIn()
        && applicationId == request.resource.data.projectId + '_' + request.auth.uid
        && request.resource.data.applicantId == request.auth.uid
        && request.resource.data.ownerId == projectData(request.resource.data.projectId).ownerId
        && request.resource.data.projectTitle == projectData(request.resource.data.projectId).title
        && projectData(request.resource.data.projectId).status == 'Open'
        && request.resource.data.ownerId != request.auth.uid
        && request.resource.data.status == 'Pending';
      allow read: if signedIn()
        && (resource.data.applicantId == request.auth.uid
          || resource.data.ownerId == request.auth.uid
          || (
            resource.data.status == 'Accepted'
            && isAcceptedProjectMember(resource.data.projectId)
          ));
      allow update: if signedIn()
        && (
          (
            resource.data.ownerId == request.auth.uid
            && (
              (
                request.resource.data.diff(resource.data).changedKeys().hasOnly([
                  'status',
                  'chatId',
                  'updatedAt'
                ])
                && resource.data.status == 'Pending'
                && request.resource.data.status in ['Accepted', 'Rejected']
              )
              || (
                request.resource.data.diff(resource.data).changedKeys().hasOnly([
                  'projectTitle',
                  'updatedAt'
                ])
                && request.resource.data.projectTitle == projectData(resource.data.projectId).title
              )
              || (
                request.resource.data.diff(resource.data).changedKeys().hasOnly([
                  'status',
                  'updatedAt'
                ])
                && resource.data.status == 'Accepted'
                && request.resource.data.status == 'Removed'
              )
            )
          )
          || (
            resource.data.applicantId == request.auth.uid
            && request.resource.data.diff(resource.data).changedKeys().hasOnly([
              'status',
              'updatedAt'
            ])
            && resource.data.status == 'Accepted'
            && request.resource.data.status == 'Left'
          )
        );
      allow delete: if signedIn()
        && (
          resource.data.ownerId == request.auth.uid
          || (
            applicationId == resource.data.projectId + '_' + request.auth.uid
            && resource.data.applicantId == request.auth.uid
            && resource.data.status in ['Pending', 'pending']
            && withdrawalKeepsApplicantCountSafe(resource.data.projectId)
          )
        );
    }

    match /chats/{chatId} {
      allow read: if signedIn()
        && request.auth.uid in resource.data.members;
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.applicantId != request.auth.uid
        && request.resource.data.projectId is string
        && request.resource.data.projectTitle == projectData(request.resource.data.projectId).title
        && projectData(request.resource.data.projectId).ownerId == request.auth.uid
        && request.resource.data.members.size() == 2
        && request.resource.data.members.hasAll([request.auth.uid, request.resource.data.applicantId])
        && existsAfter(chatApplicationPath(request.resource.data.projectId, request.resource.data.applicantId))
        && getAfter(chatApplicationPath(request.resource.data.projectId, request.resource.data.applicantId)).data.status == 'Accepted';
      allow update: if signedIn()
        && request.resource.data.projectId == resource.data.projectId
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.applicantId == resource.data.applicantId
        && request.resource.data.createdAt == resource.data.createdAt
        && (
          (
            request.resource.data.members == resource.data.members
            && request.auth.uid in resource.data.members
            && request.resource.data.projectTitle == resource.data.projectTitle
            && request.resource.data.diff(resource.data).changedKeys().hasOnly([
              'lastMessage',
              'lastMessageAt',
              'updatedAt'
            ])
          )
          || (
            request.resource.data.members == resource.data.members
            && request.auth.uid in resource.data.members
            && request.resource.data.projectTitle == resource.data.projectTitle
            && request.resource.data.diff(resource.data).changedKeys().hasOnly([
              'typing'
            ])
          )
          || (
            request.resource.data.members == resource.data.members
            && request.auth.uid in resource.data.members
            && request.resource.data.projectTitle == resource.data.projectTitle
            && request.resource.data.diff(resource.data).changedKeys().hasOnly([
              'readReceipts'
            ])
          )
          || (
            resource.data.ownerId == request.auth.uid
            && request.resource.data.diff(resource.data).changedKeys().hasOnly([
              'projectTitle',
              'updatedAt'
            ])
            && request.resource.data.projectTitle == projectData(resource.data.projectId).title
          )
          || (
            request.resource.data.diff(resource.data).changedKeys().hasOnly([
              'members',
              'updatedAt'
            ])
            && request.resource.data.members.size() == 1
            && request.resource.data.members.hasAll([resource.data.ownerId])
            && existsAfter(chatApplicationPath(resource.data.projectId, resource.data.applicantId))
            && (
              (
                resource.data.ownerId == request.auth.uid
                && getAfter(chatApplicationPath(resource.data.projectId, resource.data.applicantId)).data.status == 'Removed'
              )
              || (
                resource.data.applicantId == request.auth.uid
                && getAfter(chatApplicationPath(resource.data.projectId, resource.data.applicantId)).data.status == 'Left'
              )
            )
          )
        );
      allow delete: if signedIn()
        && resource.data.ownerId == request.auth.uid;

      match /messages/{messageId} {
        allow read: if isChatMember(chatId);
        allow create: if isChatMember(chatId)
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 2000
          && request.resource.data.keys().hasOnly([
            'senderId',
            'senderName',
            'text',
            'createdAt'
          ]);
        allow update: if false;
        allow delete: if signedIn()
          && get(chatPath(chatId)).data.ownerId == request.auth.uid;
      }
    }

    match /notifications/{notificationId} {
      allow read: if signedIn()
        && resource.data.userId == request.auth.uid;
      allow create: if signedIn()
        && request.resource.data.userId is string
        && request.resource.data.type in [
          'application-accepted',
          'application-rejected',
          'application-new',
          'application-withdrawn',
          'member-removed',
          'member-left',
          'chat-message'
        ]
        && request.resource.data.read == false
        && request.resource.data.keys().hasOnly([
          'userId',
          'type',
          'title',
          'message',
          'link',
          'read',
          'createdAt'
        ]);
      allow update: if signedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'read',
          'updatedAt'
        ])
        && request.resource.data.read == true;
      allow delete: if false;
    }
  }
}
